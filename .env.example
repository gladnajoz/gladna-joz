# Cloud sync (Supabase). Copy this file to ".env" and fill in the two values
# from your Supabase project: Settings -> API.
# Leave them blank/absent to keep the app on per-device localStorage.
#
# These are VITE_-prefixed on purpose: the anon (public) key is meant to ship in
# the client. Never put a Supabase *service_role* key here — that one is secret.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional passcode lock. Set a code (e.g. 1234) to require it before the app
# opens. Leave blank for no lock.
VITE_APP_PIN=
